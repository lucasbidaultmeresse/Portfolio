            </div>
            <p class="screenshot-caption">Messagerie textuelle (conversation).</p>
        </div>

        <div class="screenshot-container">
            <div class="screenshot-frame">
                <img src="/assets/images/greenpulse/Preferences_GreenPulse.png" alt="Préférences" onclick="openLightbox(this)" style="cursor: zoom-in;">
            </div>
            <p class="screenshot-caption">Préférences de l'utilisateurs.</p>
        </div>

        <div class="screenshot-container">
            <div class="screenshot-frame">
                <img src="/assets/images/greenpulse/Produits_GreenPulse.png" alt="Liste produits" onclick="openLightbox(this)" style="cursor: zoom-in;">
            </div>
            <p class="screenshot-caption">Liste des produits disponibles.</p>
        </div>

        <div class="screenshot-container">
            <div class="screenshot-frame">
                <img src="/assets/images/greenpulse/QR_Code_GreenPulse.png" alt="QR Code" onclick="openLightbox(this)" style="cursor: zoom-in;">
            </div>
            <p class="screenshot-caption">QR Code associé à un produit.</p>
        </div>

        <div class="screenshot-container">
            <div class="screenshot-frame">
                <img src="/assets/images/greenpulse/Theme_Sombre_GreenPulse.png" alt="Thème sombre" onclick="openLightbox(this)" style="cursor: zoom-in;">
            </div>
            <p class="screenshot-caption">Thème sombre.</p>
        </div>

    </div> 
</section>

            <div class="final-action" style="margin-top: 40px; text-align: center;">
