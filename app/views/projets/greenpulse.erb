            </div>
            <p class="screenshot-caption">Ajouter un nouveau produit en tant qu'agriculteur.</p>
        </div>

        <div class="screenshot-container">
            <div class="screenshot-frame">
                <img src="/assets/images/greenpulse/Ajouter_Produit_GreenPulse2.png" alt="Ajout produit suite" onclick="openLightbox(this)" style="cursor: zoom-in;">
            </div>
            <p class="screenshot-caption">Ajouter un nouveau produit en tant qu'agriculteur (suite).</p>
        </div>

